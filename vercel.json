{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/fdw-extract.js": { "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/plaid-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/fdw-qbo-sync",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/fdw-extract",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/ap-sync",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/fdw-samsara",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/ar-snapshot",
      "schedule": "0 10 * * *"
    }
  ]
}
